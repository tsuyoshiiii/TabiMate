<h3>Posts</h3>
  <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Body</th>
        <th></th>
      </tr>
    </thead>

    <tbody>
       <% @posts.each do |post| %>
          <tr>
            <td> <%= post.title %> </td>
            <td> <%= post.body %> </td>
          </tr>
        <% end %>
    </tbody>
  </table>