<h2>Editing Post</h2>
  <%= form_with model: @post do |f| %>
    <h4>Title</h4>
      <div>
        <%= f.text_field :title %>  
      </div>

    <h4>Body</h4>
      <div>
        <%= f.text_area :body %>
      </div>

      <div>
        <%= f.submit 'Update Post' %>
      </div>  
  <% end %>

  <a href="<%= post_path %>">Show</a> |
  <a href="<%= posts_path %>">Back</a>
